# USPTO Patent Filing Assistant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — only .env.example is committed

# ── Required ─────────────────────────────────────────────────────
# Anthropic Claude API Key — get from https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ── Supabase (Required for auth + cloud sync) ───────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY

# ── Optional ─────────────────────────────────────────────────────
# Application version (set automatically by CI/CD)
VITE_APP_VERSION=1.0.0

# Environment identifier
VITE_ENVIRONMENT=development
